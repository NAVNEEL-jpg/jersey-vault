{
  "name": "jersey-vault",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "npm start --workspace=jersey-vault-client",
    "server": "npm start --workspace=jersey-vault-server",
    "dev": "concurrently \"npm start --workspace=jersey-vault-client\" \"npm run dev --workspace=jersey-vault-server\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
